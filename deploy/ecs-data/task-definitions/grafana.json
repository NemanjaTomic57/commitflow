{
  "family": "commitflow-grafana",
  "runtimePlatform": { "operatingSystemFamily": "LINUX" },
  "taskRoleArn": "arn:aws:iam::761018874759:role/ECSCommitFlowTaskRole",
  "executionRoleArn": "arn:aws:iam::761018874759:role/ECSCommitFlowTaskExecutionRole",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "grafana",
      "image": "grafana/grafana:12.2",
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environmentFiles": [
        {
          "value": "arn:aws:s3:::commitflow-761018874759/env/grafana.env",
          "type": "s3"
        }
      ],
      "secrets": [
        {
          "name": "GF_SECURITY_ADMIN_PASSWORD",
          "valueFrom": "arn:aws:ssm:eu-central-1:761018874759:parameter/commitflow/passwords/grafana"
        },
        {
          "name": "GF_DATABASE_PASSWORD",
          "valueFrom": "arn:aws:ssm:eu-central-1:761018874759:parameter/commitflow/passwords/postgres"
        }
      ],
      "linuxParameters": {
        "initProcessEnabled": true
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/commitflow",
          "awslogs-region": "eu-central-1",
          "awslogs-stream-prefix": "grafana"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:3000/api/health"],
        "interval": 10,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "tags": [
    {
      "key": "Name",
      "value": "CommitFlowGrafana"
    }
  ],
  "pidMode": "task"
}
