{
  "family": "commitflow-producer",
  "runtimePlatform": { "operatingSystemFamily": "LINUX" },
  "taskRoleArn": "arn:aws:iam::761018874759:role/ECSCommitFlowTaskRole",
  "executionRoleArn": "arn:aws:iam::761018874759:role/ECSCommitFlowTaskExecutionRole",
  "networkMode": "awsvpc",
  "containerDefinitions": [
    {
      "name": "producer",
      "image": "761018874759.dkr.ecr.eu-central-1.amazonaws.com/commitflow:latest",
      "essential": true,
      "command": ["producer", "-bootstrap"],
      "environmentFiles": [
        {
          "value": "arn:aws:s3:::commitflow-761018874759/env/commitflow.env",
          "type": "s3"
        }
      ],
      "secrets": [
        {
          "name": "GITHUB_PAT",
          "valueFrom": "arn:aws:ssm:eu-central-1:761018874759:parameter/commitflow/passwords/github-pat"
        },
        {
          "name": "GITLAB_PAT",
          "valueFrom": "arn:aws:ssm:eu-central-1:761018874759:parameter/commitflow/passwords/gitlab-pat"
        }
      ],
      "linuxParameters": {
        "initProcessEnabled": true
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/commitflow",
          "awslogs-region": "eu-central-1",
          "awslogs-stream-prefix": "producer"
        }
      }
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "tags": [
    {
      "key": "Name",
      "value": "CommitFlowProducer"
    }
  ],
  "pidMode": "task"
}
